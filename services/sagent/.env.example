# ─────────────────────────────────────────────────────────────────────────────
# Development environment variables (sagent/.env.example)
# Copy to .env or .env.development and fill in actual values.
# .env / .env.development are gitignored — DO NOT commit secrets.
#
# All variables are read centrally by config/settings.py.
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP / Vertex AI ──────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── Application ──────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
PORT=8000
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (PostgreSQL) ────────────────────────────────────────────────
# Start with: docker compose up -d postgres
DATABASE_URL=postgresql://agent:localdev@localhost:5433/agent

# ── RabbitMQ (sagent ↔ retrieval communication) ────────────────────────
RABBITMQ_URL=amqp://agent:localdev@rabbitmq:5672/
# QUEUE_RAG_REQUESTS=rag_requests
# QUEUE_INDEXING=indexing_tasks
# RAG_RPC_TIMEOUT=30

# ── MinIO (S3-compatible artifact storage) ──────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agent-artifacts
MINIO_SECURE=false
# Public URL for artifact downloads (via nginx reverse proxy)
MINIO_PUBLIC_URL=http://localhost:8081/storage

# ── RAG Settings ──────────────────────────────────────────────────────
# RAG_SIMILARITY_TOP_K=10
# RAG_CHUNK_SIZE=512
# RAG_CHUNK_OVERLAP=100

# ── Team Membership ─────────────────────────────────────────────────────
# TEAM_MEMBERSHIP_PROVIDER=database   # database | google_groups | azure_ad

# ── Logging ─────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# ADK_LOG_LEVEL=INFO

# ── Production Overrides ────────────────────────────────────────────────
# ENVIRONMENT=production
# ARTIFACT_BUCKET=agent-artifacts-prod
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance

# ── Docker Compose Port Overrides ───────────────────────────────────────
# Non-default ports to avoid conflicts with other local projects.
# Override in .env if needed:
# POSTGRES_PORT=5433        # Default: 5433 (avoids 5432)
# MINIO_API_PORT=9010       # Default: 9010 (avoids 9000)
# MINIO_CONSOLE_PORT=9011   # Default: 9011 (avoids 9001)
# RABBITMQ_PORT=5673        # Default: 5673 (avoids 5672)
# RABBITMQ_MGMT_PORT=15673  # Default: 15673 (avoids 15672)
# NGINX_PORT=8081           # Default: 8081 (avoids 80/8080)
