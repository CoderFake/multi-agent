# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Reference for all configuration keys
# Copy to .env (project root, same level as docker-compose.yml) and fill in.
# .env is gitignored — DO NOT commit secrets.
#
# All variables are read by sagent/config/settings.py
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP / Vertex AI ── (REQUIRED) ────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (PostgreSQL) ── (REQUIRED) ───────────────────────────────────────
# Local dev: docker compose up -d postgres  (mapped to port 5433)
DATABASE_URL=postgresql://agent:localdev@localhost:5433/agent
# Production (Cloud SQL via Unix socket):
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance

# ── RabbitMQ (sagent ↔ retrieval) ────────────────────────────────────────────
# Local dev: docker compose up -d rabbitmq  (mapped to port 5673)
RABBITMQ_URL=amqp://agent:localdev@localhost:5673/
QUEUE_RAG_REQUESTS=rag_requests
QUEUE_INDEXING=indexing_tasks
RAG_RPC_TIMEOUT=30

# ── RAG Settings ──────────────────────────────────────────────────────────────
RAG_SIMILARITY_TOP_K=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=100

# ── Team Membership ───────────────────────────────────────────────────────────
TEAM_MEMBERSHIP_PROVIDER=database   # database | google_groups | azure_ad

# ── Artifact Storage ──────────────────────────────────────────────────────────
# Production: set to your GCS bucket name
ARTIFACT_BUCKET=
# Dev: leave empty — MinIO is used instead (configured below)

# ── MinIO (S3-compatible artifact storage — dev only) ─────────────────────────
# Local dev: docker compose up -d minio  (API on port 9010, console on 9011)
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET=<your-minio-bucket>
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:8081/storage

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ADK_LOG_LEVEL=

# ── Model Config ──────────────────────────────────────────────────────────────
# Change model without touching code. Defaults shown.
MODEL_ROOT=gemini-2.5-pro
MODEL_SEARCH=gemini-2.5-flash
MODEL_RAG=gemini-2.5-flash
MODEL_DATA_ANALYST=gemini-2.5-pro
MODEL_TITLE=gemini-2.0-flash-lite

# ── Docker Compose Port Overrides ─────────────────────────────────────────────
# Override if default ports conflict with other local services.
POSTGRES_PORT=5433
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
RABBITMQ_PORT=5673
RABBITMQ_MGMT_PORT=15673
NGINX_PORT=8081
