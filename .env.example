# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Reference for all configuration keys
# Copy to .env (project root, same level as docker-compose.yml) and fill in.
# .env is gitignored — DO NOT commit secrets.
#
# Shared by ALL services:
#   - sagent/         (FastAPI agent backend)   reads via config/settings.py
#   - services/retrieval/ (FastAPI retrieval)   reads directly via os.getenv
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP / Vertex AI ── (REQUIRED) ────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | production
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Database (PostgreSQL) ── (REQUIRED) ───────────────────────────────────────
# Local dev: docker compose up -d postgres  (mapped to port 5433)
DATABASE_URL=postgresql://agent:localdev@localhost:5433/agent
# Production (Cloud SQL via Unix socket):
# DATABASE_URL=postgresql://user:pass@/dbname?host=/cloudsql/project:region:instance

# ── RabbitMQ (sagent ↔ retrieval) ────────────────────────────────────────────
# Local dev: docker compose up -d rabbitmq  (mapped to port 5673)
RABBITMQ_URL=amqp://agent:localdev@localhost:5673/
QUEUE_RAG_REQUESTS=rag_requests
QUEUE_INDEXING=indexing_tasks
RAG_RPC_TIMEOUT=30

# ── RAG Settings ──────────────────────────────────────────────────────────────
RAG_SIMILARITY_TOP_K=10
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=100

# ── Team Membership ───────────────────────────────────────────────────────────
TEAM_MEMBERSHIP_PROVIDER=database   # database | google_groups | azure_ad

# ── Artifact Storage ──────────────────────────────────────────────────────────
# Production: set to your GCS bucket name
ARTIFACT_BUCKET=
# Dev: leave empty — MinIO is used instead (configured below)

# ── MinIO (S3-compatible artifact storage — dev only) ─────────────────────────
# MinIO has TWO URL contexts — use the right one per scenario:
#
#   MINIO_ENDPOINT   = host:port that sagent uses to READ/WRITE artifacts (S3 API)
#     → sagent running on HOST machine:   localhost:9010   (mapped Docker port)
#     → sagent running IN Docker:          minio:9000       (Docker internal DNS)
#
#   MINIO_PUBLIC_URL = URL that BROWSER/FRONTEND uses to DOWNLOAD artifacts
#     → always uses nginx as reverse proxy: http://localhost:8081/storage
#     → nginx internally forwards to minio:9000 (never exposed directly to client)
#     → this separates read/write access (sagent) from download access (client)
#
# Default: sagent on host machine
MINIO_ENDPOINT=localhost:9010
# If sagent is also containerised, change to:
# MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=<your-minio-access-key>
MINIO_SECRET_KEY=<your-minio-secret-key>
MINIO_BUCKET=agent-artifacts
MINIO_SECURE=false
MINIO_PUBLIC_URL=http://localhost:8081/storage

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ADK_LOG_LEVEL=

# ── Model Config ──────────────────────────────────────────────────────────────
# Override any model without touching code. Defaults shown below.
MODEL_ROOT=gemini-3-flash-preview
MODEL_SEARCH=gemini-2.5-flash
MODEL_RAG=gemini-2.5-flash
MODEL_DATA_ANALYST=gemini-2.5-pro
MODEL_TITLE=gemini-2.5-flash

# ── CMS Backend ───────────────────────────────────────────────────────────────
# Read by backend/app/config/settings.py (CMS service on port 8002)
# Uses separate 'cms' database to avoid conflicts with sagent's 'agent' DB.
CMS_PORT=8002
CMS_DATABASE_URL=postgresql+asyncpg://agent:localdev@localhost:5433/cms
REDIS_URL=redis://localhost:6380/0
JWT_SECRET_KEY=<change-this-in-production>
ENCRYPTION_KEY=<generate-with-python-fernet>

# ── Docker Compose Port Overrides ─────────────────────────────────────────────
# Non-default ports to avoid conflicts with other local projects.
POSTGRES_PORT=5433
REDIS_PORT=6380
MINIO_API_PORT=9010
MINIO_CONSOLE_PORT=9011
RABBITMQ_PORT=5673
RABBITMQ_MGMT_PORT=15673
NGINX_PORT=8081

# ── Retrieval Microservice ─────────────────────────────────────────────────────
# Read by services/retrieval/app/config/settings.py
# (RABBITMQ_URL, QUEUE_*, DATABASE_URL above are shared with sagent)

# Milvus vector database
# sagent/retrieval on HOST, milvus in Docker:
MILVUS_HOST=localhost
MILVUS_PORT=19535
# retrieval container INSIDE Docker (change when containerised):
# MILVUS_HOST=milvus
# MILVUS_PORT=19530

# Embedding model (sentence-transformers, runs inside retrieval service)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Search defaults
DEFAULT_TOP_K=10
